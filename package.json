{
   "name": "agljs",
   "version": "1.1.0",
   "description": "A lightweight framework for integrating web apps with Epic's Active Guidelines platform, using modern JavaScript features. Manage action queuing, event handling, subscriptions, and state within Epic Hyperspace.",
   "main": "js/agl.js",
   "module": "js/agl.mjs",
   "types": "agl.d.ts",
   "exports": {
      ".": {
         "types": "./agl.d.ts",
         "import": "./js/agl.mjs",
         "require": "./js/agl.js",
         "default": "./js/agl.js"
      },
      "./js/*": "./js/*",
      "./package.json": "./package.json"
   },
   "sideEffects": false,
   "files": [
      "js/",
      "ts/",
      "agl.d.ts"
   ],
   "repository": {
      "type": "git",
      "url": "https://github.com/faulkj/agljs.git"
   },
   "bugs": {
      "url": "https://github.com/faulkj/agljs/issues"
   },
   "homepage": "https://github.com/faulkj/agljs#readme",
   "author": "Joshua Faulkenberry <j@joshuafaulkenberry.com> (https://joshuafaulkenberry.com/)",
   "license": "Kopimi",
   "keywords": [
      "Epic",
      "Epic Hyperspace",
      "Epic Hyperdrive",
      "Active Guidelines",
      "AGL",
      "TypeScript",
      "EHR",
      "clinical decision support",
      "CDS",
      "healthcare"
   ],
   "scripts": {
      "typecheck": "tsc --noEmit",
      "build": "npm run typecheck && rollup -c",
      "prepack": "npm run build"
   },
   "devDependencies": {
      "@rollup/plugin-terser": "^1.0.0",
      "esbuild": "^0.28.1",
      "rollup": "^4.62.2",
      "rollup-plugin-esbuild": "^6.2.1",
      "tslib": "^2.8.1",
      "typescript": "^7.0.2"
   }
}
